# Copy to .env and adjust. Defaults below match docker-compose.yml at repository root.

# PostgreSQL (matches root docker-compose postgres service)
DATABASE_URL=postgres://admindb:gonsgarage123@localhost:5432/gonsgarage?sslmode=disable

# Redis: host:port only (used as redis.Options.Addr). No password in default compose.
REDIS_URL=localhost:6379

JWT_SECRET=change-me-in-production
SERVER_PORT=8080
GIN_MODE=debug

# Set to "true" only in local dev to drop tables before AutoMigrate (destructive).
# RESET_DATABASE=false
