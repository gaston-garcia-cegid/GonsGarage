# Copy to `.env.local` (Next.js no lee `env.local` sin el punto).

# Origen del API (recomendado): host + puerto. El cliente añade `/api/v1` internamente.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Alternativa (p. ej. build Docker): URL ya con `/api/v1` — no se duplica.
# NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
