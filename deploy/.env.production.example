# Ejemplo para docker-compose.prod.yml (copiar a la raíz del repo como `.env` — nunca commitear).

# PostgreSQL (usuario/clave que usará el contenedor postgres)
POSTGRES_DB=gonsgarage
POSTGRES_USER=gonsgarage
POSTGRES_PASSWORD=change_me_strong_password

# DSN que usa la API (host `postgres` es el nombre del servicio en compose)
DATABASE_URL=postgres://gonsgarage:change_me_strong_password@postgres:5432/gonsgarage?sslmode=disable

# JWT: obligatorio con GIN_MODE=release en la imagen API
JWT_SECRET=use_openssl_rand_hex_32_or_longer_random_string

# Redis dentro de la red compose
REDIS_URL=redis:6379

# URL pública de la API tal como la ve el navegador (ej. https://api.tudominio.com)
NEXT_PUBLIC_API_URL=https://api.tudominio.com

# Puertos publicados en el host
API_PUBLISH_PORT=8080
WEB_PUBLISH_PORT=3000
