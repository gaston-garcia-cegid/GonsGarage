# Ejemplo para docker-compose.prod.yml (copiar a la raíz del repo como `.env` — nunca commitear).

# PostgreSQL (usuario/clave que usará el contenedor postgres)
POSTGRES_DB=gonsgarage
POSTGRES_USER=gonsgarage
POSTGRES_PASSWORD=change_me_strong_password

# DSN que usa la API (host `postgres` es el nombre del servicio en compose).
# golang-migrate usa por defecto la tabla gon_golang_migrate (no public.schema_migrations) para no chocar con otros migradores.
# Para forzar otra tabla: añadí ?...&x-migrations-table=nombre_tabla
DATABASE_URL=postgres://gonsgarage:change_me_strong_password@postgres:5432/gonsgarage?sslmode=disable

# JWT: obligatorio con GIN_MODE=release en la imagen API
JWT_SECRET=use_openssl_rand_hex_32_or_longer_random_string

# CORS: orígenes del SPA (coma-separada). Requerido para llamadas cross-origin desde el navegador.
CORS_ALLOWED_ORIGINS=https://app.tudominio.com

# Redis dentro de la red compose
REDIS_URL=redis:6379

# Cola Redis consumida por el worker (LPUSH desde tooling / futura API)
WORKER_QUEUE_KEY=gonsgarage:jobs

# golang-migrate: cadena SQL bajo backend/db/migrations (15 revisiones de ejemplo). En la imagen API: /app/db/migrations
ENABLE_SQL_MIGRATIONS=true
MIGRATIONS_DIR=/app/db/migrations
# Solo desarrollo: si golang-migrate quedó "dirty" tras un fallo, true ejecuta Force antes de Up (no usar en release).
MIGRATE_AUTO_FIX_DIRTY=false
# Solo si el esquema lo gestionan migraciones SQL exclusivamente:
SKIP_GORM_AUTOMIGRATE=false

# Rate limit por IP en POST /api/v1/auth/login y /register
AUTH_RATE_LIMIT_RPS=5
AUTH_RATE_LIMIT_BURST=10
AUTH_RATE_LIMIT_DISABLED=false

# URL pública del API para el SPA (mismo origen que Nginx si usas edge)
# Ejemplo con Nginx en localhost:8080 → el API en el navegador es /api/v1 bajo ese host:
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Puerto publicado del reverse proxy (api y web no exponen puertos al host en prod)
HTTP_PUBLISH_PORT=8080
