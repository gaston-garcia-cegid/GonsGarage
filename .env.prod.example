# ===========================================
# GonsGarage - Production Environment Variables
# ===========================================
# Copy this file to .env.prod and change the values
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Copiar a `.env.prod` en el servidor (no commitear `.env.prod`).
# Valores ejemplo para LAN 192.168.1.100:8102 (nginx único).

# URL pública que ve el navegador (mismo host/puerto que nginx; sin /api/v1).
NEXT_PUBLIC_API_URL=http://192.168.1.100:8102

# Orígenes CORS permitidos con GIN_MODE=release (separados por coma). Debe incluir la URL del front.
CORS_ORIGINS=http://192.168.1.100:8102

# --- JWT ---
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_jwt_secret_here
JWT_EXPIRY_HOURS=168
GIN_MODE=release

# Postgres en el host Docker (crear rol + DB antes). Sustituir usuario/contraseña reales.
DATABASE_URL=postgres://gonsgarage_app:CHANGE_ME_strong_password_here@host.docker.internal:5432/gonsgarage?sslmode=disable
DB_USER=gonsgarage_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=gonsgarage_db

# Redis interno del compose (sin auth; solo red Docker).
REDIS_URL=redis:6379
